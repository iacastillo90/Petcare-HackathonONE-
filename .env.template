# ===================================================================
# Petcare Application - Environment Variables Template
# ===================================================================
# Copiar este archivo a .env y completar los valores
# ===================================================================

# Perfil y Puerto
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8088

# DB - MySQL (usar los datos de tu proveedor de DBaaS o docker)
SPRING_DATASOURCE_URL=jdbc:mysql://HOST:PORT/DATABASE
SPRING_DATASOURCE_USERNAME=tu_usuario
SPRING_DATASOURCE_PASSWORD=tu_password

# SMTP (Gmail u otro proveedor)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=tu_mail@gmail.com
SPRING_MAIL_PASSWORD=tu_app_password

# JWT - Generar con: openssl rand -base64 64
JWT_SECRET=tu_jwt_secret_aqui
JWT_EXPIRATION=86400000

# MySQL (solo para docker compose local)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=petcare
MYSQL_USER=petcare_user
MYSQL_PASSWORD=petcare_pass
