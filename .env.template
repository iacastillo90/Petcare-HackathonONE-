# =============================================================================
# Petcare Application - Environment Variables Template
# =============================================================================
# Copiar este archivo a .env y completar con valores reales
# NO subir .env a repositorios (ya está excluido en .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=petcare
SPRING_DATASOURCE_USERNAME=petcare_user
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD_HERE

# -----------------------------------------------------------------------------
# JWT Configuration - CRITICAL SECURITY
# -----------------------------------------------------------------------------
# Generar con: openssl rand -base64 256
# IMPORTANTE: Usar una clave diferente en producción
JWT_SECRET=YOUR_256_BIT_BASE64_ENCODED_SECRET_KEY_HERE

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# Para Gmail usar App Password (no tu password normal)
# https://support.google.com/accounts/answer/185833
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=YOUR_APP_PASSWORD_HERE

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_DEBUG=false
APP_URL=http://localhost:8088
